# BUG FIX #2d: Tambahkan connection_limit dan pool_timeout di DATABASE_URL
# connection_limit=10 artinya max 10 koneksi DB bersamaan (default Prisma = 5, terlalu kecil)
DATABASE_URL="mysql://root:password@localhost:3306/billiard_pos?connection_limit=10&pool_timeout=20"

JWT_SECRET="change-this-in-production-32chars+"
JWT_REFRESH_SECRET="change-this-refresh-secret-32chars+"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
PORT=3001

# BUG FIX: Untuk multiple origin, pisahkan dengan koma
# Contoh: CORS_ORIGIN="http://localhost:3000,https://pos.v-luxe.id"
CORS_ORIGIN="http://localhost:3000"

IOT_HMAC_SECRET="change-this-iot-secret"
IOT_NONCE_WINDOW_SECONDS=300
# Optional: enable single-ESP gateway mode
IOT_GATEWAY_DEVICE_ID=""

NODE_ENV="production"

# QZ Tray signing (disarankan untuk deployment web hosted)
QZ_CERTIFICATE=
QZ_PRIVATE_KEY=
QZ_SIGN_API_KEY=
